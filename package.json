{
  "name": "misp-mcp",
  "version": "1.3.2",
  "description": "MCP server for MISP threat intelligence platform - IOC lookups, event management, correlation discovery, and intelligence enrichment",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mispctrl": "./dist/cli.js",
    "mispctl": "./dist/cli.js",
    "misp-mcp": "./dist/mcp-bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/mcp-bin.ts",
    "start": "node dist/mcp-bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidless-labs/misp-mcp.git"
  },
  "homepage": "https://github.com/lidless-labs/misp-mcp#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/misp-mcp/issues"
  },
  "keywords": [
    "mcp",
    "misp",
    "threat-intelligence",
    "soc",
    "security",
    "ioc",
    "indicators-of-compromise",
    "malware-analysis"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^8.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "overrides": {
    "esbuild": "0.28.1",
    "hono": "4.12.27"
  },
  "packageManager": "npm@10.9.7"
}
